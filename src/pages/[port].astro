---
import { ports, getPort } from '~/lib/ports';
import { coverageStatus, getPortDayWindow, portData } from '~/lib/data';
import { isoDate, next5Days } from '~/lib/time';
import Forecast from '~/components/Forecast.svelte';
import '~/styles/global.css';

export function getStaticPaths() {
  return ports.map((p) => ({ params: { port: p.slug } }));
}

const { port: portSlug } = Astro.params as { port: string };
const port = getPort(portSlug);
if (!port) {
  return Astro.redirect('/');
}

const today = isoDate(new Date());
const dates = next5Days(today);
const cards = dates.map((date, i) => ({
  date,
  events: getPortDayWindow(portSlug, date),
  isToday: i === 0,
}));

const allDays = portData[portSlug]?.days ?? {};
const labelKind: 'registado' | 'anual' =
  Object.keys(allDays).length >= 365 ? 'anual' : 'registado';

const portFile = portData[portSlug];
const coverage = portFile
  ? coverageStatus(portFile, dates, new Date())
  : null;
---

<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{port!.name} — Marés</title>
    <meta property="og:title" content={`Marés em ${port!.name}`} />
    <meta
      property="og:description"
      content={`Previsões de marés nos próximos 5 dias em ${port!.name}, Portugal.`}
    />
  </head>
  <body>
    <main>
      <header class="port-header">
        <h1>{port!.name}</h1>
        <button
          type="button"
          class="share-button"
          aria-label="Partilhar"
          data-share-url={`/${portSlug}`}
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7" />
            <polyline points="16 6 12 2 8 6" />
            <line x1="12" y1="2" x2="12" y2="15" />
          </svg>
        </button>
        <span class="copy-toast" data-copy-toast hidden>Link copiado ✓</span>
      </header>
      <script is:inline>
        (() => {
          const btn = document.querySelector('.share-button');
          const toast = document.querySelector('[data-copy-toast]');
          if (!btn || !toast) return;
          let toastTimer;
          const showToast = () => {
            toast.hidden = false;
            clearTimeout(toastTimer);
            toastTimer = setTimeout(() => {
              toast.hidden = true;
            }, 2000);
          };
          btn.addEventListener('click', async () => {
            const url = window.location.href;
            if (navigator.share) {
              try {
                await navigator.share({ url });
                return;
              } catch (err) {
                if (err && err.name === 'AbortError') return;
              }
            }
            try {
              await navigator.clipboard.writeText(url);
              showToast();
            } catch {}
          });
        })();
      </script>
      {coverage?.windowIncomplete && (
        <div class="stale-banner" data-banner="window-incomplete">
          Sem dados completos para esta semana — fonte temporariamente indisponível.
        </div>
      )}
      {coverage?.sourceQuiet && (
        <div class="stale-banner" data-banner="source-quiet">
          Fonte sem atualizações há {coverage.ageDays} dias — dados podem desatualizar em breve.
        </div>
      )}
      <Forecast client:load cards={cards} port={port} allDays={allDays} labelKind={labelKind} />
    </main>
  </body>
</html>
