---
import { ports, getPort } from '~/lib/ports';
import { coverageStatus, getPortDayWindow, portData } from '~/lib/data';
import { isoDate, next5Days } from '~/lib/time';
import Forecast from '~/components/Forecast.svelte';
import Footer from '~/components/Footer.astro';
import '~/styles/global.css';

export function getStaticPaths() {
  return ports.map((p) => ({ params: { port: p.slug } }));
}

const { port: portSlug } = Astro.params as { port: string };
const port = getPort(portSlug);
if (!port) {
  return Astro.redirect('/');
}

const today = isoDate(new Date());
const dates = next5Days(today);
const cards = dates.map((date, i) => ({
  date,
  events: getPortDayWindow(portSlug, date),
  isToday: i === 0,
}));

const allDays = portData[portSlug]?.days ?? {};
const labelKind: 'registado' | 'anual' =
  Object.keys(allDays).length >= 365 ? 'anual' : 'registado';

const portFile = portData[portSlug];
const coverage = portFile
  ? coverageStatus(portFile, dates, new Date())
  : null;
---

<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{port!.name} — Marés</title>
    <meta property="og:title" content={`Marés em ${port!.name}`} />
    <meta
      property="og:description"
      content={`Previsões de marés nos próximos 5 dias em ${port!.name}, Portugal.`}
    />
    <link id="favicon" rel="icon" type="image/svg+xml" href="/icon-dark.svg" />
    <script is:inline>
      (() => {
        const docEl = document.documentElement;
        let theme;
        try {
          const saved = localStorage.getItem('mare-theme');
          if (saved === 'light' || saved === 'dark') {
            docEl.setAttribute('data-theme', saved);
            theme = saved;
          }
        } catch (_) {}
        if (!theme) {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches
            ? 'dark'
            : 'light';
        }
        const fav = document.getElementById('favicon');
        if (fav) fav.href = theme === 'dark' ? '/icon-light.svg' : '/icon-dark.svg';
      })();
    </script>
  </head>
  <body>
    <main>
      <header class="port-header">
        <h1>{port!.name}</h1>
        <button
          type="button"
          class="theme-toggle"
          data-theme-toggle
          aria-label="Alternar tema claro / escuro"
          title="Alternar tema"
        >
          <svg
            class="glyph-moon"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79z" />
          </svg>
          <svg
            class="glyph-sun"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.7"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
        </button>
        <button
          type="button"
          class="share-button"
          aria-label="Partilhar"
          data-share-url={`/${portSlug}`}
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 12v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7" />
            <polyline points="16 6 12 2 8 6" />
            <line x1="12" y1="2" x2="12" y2="15" />
          </svg>
        </button>
        <span class="copy-toast" data-copy-toast hidden>Link copiado ✓</span>
      </header>
      <script is:inline>
        (() => {
          const btn = document.querySelector('.share-button');
          const toast = document.querySelector('[data-copy-toast]');
          if (btn && toast) {
            let toastTimer;
            const showToast = () => {
              toast.hidden = false;
              clearTimeout(toastTimer);
              toastTimer = setTimeout(() => { toast.hidden = true; }, 2000);
            };
            btn.addEventListener('click', async () => {
              const url = window.location.href;
              if (navigator.share) {
                try {
                  await navigator.share({ url });
                  return;
                } catch (err) {
                  if (err && err.name === 'AbortError') return;
                }
              }
              try {
                await navigator.clipboard.writeText(url);
                showToast();
              } catch {}
            });
          }

          const themeBtn = document.querySelector('[data-theme-toggle]');
          if (themeBtn) {
            const currentTheme = () => {
              const explicit = document.documentElement.getAttribute('data-theme');
              if (explicit === 'light' || explicit === 'dark') return explicit;
              return window.matchMedia('(prefers-color-scheme: dark)').matches
                ? 'dark'
                : 'light';
            };
            themeBtn.addEventListener('click', () => {
              const next = currentTheme() === 'dark' ? 'light' : 'dark';
              document.documentElement.setAttribute('data-theme', next);
              const fav = document.getElementById('favicon');
              if (fav) fav.setAttribute('href', next === 'dark' ? '/icon-light.svg' : '/icon-dark.svg');
              try { localStorage.setItem('mare-theme', next); } catch (_) {}
            });
          }
        })();
      </script>
      {coverage?.windowIncomplete && (
        <div class="stale-banner" data-banner="window-incomplete">
          Sem dados completos para esta semana — fonte temporariamente indisponível.
        </div>
      )}
      {coverage?.sourceQuiet && (
        <div class="stale-banner" data-banner="source-quiet">
          Fonte sem atualizações há {coverage.ageDays} dias — dados podem desatualizar em breve.
        </div>
      )}
      <Forecast client:load cards={cards} port={port} allDays={allDays} labelKind={labelKind} />
      <Footer />
    </main>
  </body>
</html>
