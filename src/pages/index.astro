---
import { ports } from '~/lib/ports';
import { portData } from '~/lib/data';
import '~/styles/global.css';
---

<html lang="pt-PT">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Marés em Portugal</title>
    <meta name="description" content="Previsões de marés para os principais portos de Portugal continental." />
  </head>
  <body>
    <main>
      <h1>Marés</h1>
      <p class="muted">Previsões para os principais portos de Portugal continental.</p>

      <div class="port-grid">
        {
          ports.map((p) => {
            const hasData = portData[p.slug] !== undefined;
            return (
              <a class="port-card" href={`/${p.slug}`}>
                <span>{p.name}</span>
                <span class="chev">{hasData ? '›' : '—'}</span>
              </a>
            );
          })
        }
      </div>
    </main>
  </body>
</html>
